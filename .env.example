# Copy this file to .env and fill in your keys. Never commit .env.
# For GitHub Actions, add these same names as repository secrets instead.
#
# Note: the default price source (Google Flights, via flightdeals/collectors/
# google_flights.py) needs NO key at all — only fill in the section below
# that you actually want to use.

# --- Telegram bot (recommended — this is how deals reach you) ---
# Create a bot with @BotFather to get the token.
# To find your chat id: message your bot once, then run
#   python -m flightdeals.alerts --get-chat-id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Optional: Amadeus for Developers (free account, more official than the
# default Google Flights source) ---
# Sign up at https://developers.amadeus.com → My Apps → Create App, then
# also set api.amadeus.enabled: true in config.yaml.
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# --- Optional: legacy Kiwi Tequila API key ---
# Tequila closed to new sign-ups in 2023. Only set this if you already
# have a key; also set api.kiwi.enabled: true in config.yaml.
KIWI_API_KEY=

# --- Optional overrides ---
# Point the app at a different config or database without editing files:
# FLIGHTDEALS_CONFIG=config.yaml
# FLIGHTDEALS_DB=data/flightdeals.db
